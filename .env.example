# Firebase (클라이언트)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (서버 전용 — JSON 한 줄로)
FIREBASE_ADMIN_SA_KEY=

# OpenAI
OPENAI_API_KEY=

# 서버 내부 호출 인증 (랜덤 32바이트 hex 권장, 외부 노출 금지)
INTERNAL_API_SECRET=


# (옵션) ElevenLabs
ELEVENLABS_API_KEY=

# Cloud Run / Tasks (렌더 큐)
GCP_PROJECT_ID=
CLOUD_TASKS_QUEUE=          # 예: render-queue (미설정 시 dev 폴백=직접 fetch)
CLOUD_TASKS_LOCATION=       # 예: asia-northeast3
RENDER_WORKER_URL=          # 로컬: http://localhost:8080 / 배포: Cloud Run URL
WORKER_SECRET=              # 워커 /render 보호용 공유 시크릿 (worker env에도 동일값)

# Worker 전용 (worker/.env)
# RENDER_PAGE_URL=http://localhost:3000/render  (로컬) / 배포: Vercel URL + /render
