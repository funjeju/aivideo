# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (모든 depth — worker/node_modules 포함)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# worker 빌드 산출물
worker/dist/
worker/.cache/

# 테스트 산출물 (이미지/영상)
scripts/*.png
scripts/*.mp4
scripts/*.mp3
